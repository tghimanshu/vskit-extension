{
  "manifest_version": 3,
  "name": "VSKit Auto Unmute and Next",
  "version": "1.0.0",
  "description": "Auto-unmutes videos on VSKit watch pages and advances to the next episode when playback ends.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://vskit.tv/watch/*",
        "https://www.vskit.tv/watch/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}